      "index": "b1G",
      "roundness": null,
      "seed": 1692374072,
      "version": 824,
      "versionNonce": 256430152,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784591928464,
      "link": null,
      "locked": false,
      "text": "Introduce a gateway so that client doesnt need to\ninteract with a complex subsystem. It decouples \nclient from the complex subsystem.",
      "fontSize": 25.790861126547554,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Introduce a gateway so that client doesnt need to \ninteract with a complex subsystem. It decouples \nclient from the complex subsystem.",
      "autoResize": false,
      "lineHeight": 1.25
    },
