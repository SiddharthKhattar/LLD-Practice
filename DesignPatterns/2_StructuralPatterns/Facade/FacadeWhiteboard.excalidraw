      "type": "text",
      "x": 702.4244844576674,
      "y": 282.8904697246796,
      "width": 662.3377373227801,
      "height": 96.71572922455333,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
