      "isDeleted": false,
      "boundElements": null,
      "updated": 1784592162918,
      "link": null,
      "locked": false,
      "text": "Take any object, now from any method in that object,\nprinciple tells you to invoke only methods that belong to:\n\n1) The object itself\n2) The object passed in as a parameter to the method\n3) Any object that method creates\n4) Any object with \"Has-a\" relationship",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Take any object, now from any method in that object, principle tells you to invoke only methods that belong to:\n\n1) The object itself\n2) The object passed in as a parameter to the method\n3) Any object that method creates\n4) Any object with \"Has-a\" relationship",
      "autoResize": false,
      "lineHeight": 1.25
    },
