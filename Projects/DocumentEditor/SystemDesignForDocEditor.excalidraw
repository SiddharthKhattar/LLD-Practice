    {
      "id": "ppIM9poTrGHB4ePArrZHN",
      "type": "text",
      "x": 1840.4979678795066,
      "y": 1360.3617894896665,
      "width": 1030.174336334353,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1K",
      "roundness": null,
      "seed": 931904727,
      "version": 1356,
      "versionNonce": 964257783,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784250859216,
      "link": null,
      "locked": false,
      "text": "Now this class is following the Single Responsibility principle better as the previous problem is not here\nBUT now the con is its sort of breaking principle of least knowledge / law of demeter (which is a\ndifferent design principle), \nwhich says that you should always talk to your immediate friends,\nthis means that a class should only call methods of classes that are DIRECTLY related to it and not\ncall methods of call that are related to it two, three or more relations away\n\nlike how this diagram here breaks it for example is that following the red dotted line here is that\ndocumentRenderer is getting the render() method from document class\n which in turn is getting it from DocumentElement class, so its two hops away\n\n--> this is basically causing tight coupling which the principle of least knowledge wants to deter against\n-> this is a tradeoff cause if we move the render method back inside the document class then we will go\nback to the prev diagam again",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Now this class is following the Single Responsibility principle better as the previous problem is not here\nBUT now the con is its sort of breaking principle of least knowledge / law of demeter (which is a different design principle), \nwhich says that you should always talk to your immediate friends,\nthis means that a class should only call methods of classes that are DIRECTLY related to it and not call methods of call that are related to it two, three or more relations away\n\nlike how this diagram here breaks it for example is that following the red dotted line here is that documentRenderer is getting the render() method from document class\n which in turn is getting it from DocumentElement class, so its two hops away\n\n--> this is basically causing tight coupling which the principle of least knowledge wants to deter against\n-> this is a tradeoff cause if we move the render method back inside the document class then we will go back to the prev diagam again",
      "autoResize": false,
      "lineHeight": 1.25
    },
