    {
      "id": "vI8GJXWBofbOUVJq82wmi",
      "type": "text",
      "x": 1407.7815002033922,
      "y": 759.7604607864397,
      "width": 491.27437533245757,
      "height": 120,
      "angle": 0,
      "strokeColor": "#868e96",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
