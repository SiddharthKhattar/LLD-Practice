      "index": "b74",
      "roundness": null,
      "seed": 1970238024,
      "version": 970,
      "versionNonce": 2142763336,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "L7LbgErC3sq0YOeguhvZu",
          "type": "arrow"
        }
      ],
      "updated": 1784789846748,
      "link": null,
      "locked": false,
      "text": "We cannot create a reference of the below IBankingSystem\nclass in this object here because its on a different server so\nit will give a compile error. We can create a remote proxy here\nthats a copy of IBankingSystem class below to mimic its\nbehavior, so the proxy in turn will call another BankingSystem\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We cannot create a reference of the below IBankingSystem class in this object here because its on a different server so it will give a compile error. We can create a remote proxy here thats a copy of IBankingSystem class below to mimic its behavior, so the proxy in turn will call another BankingSystem\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
